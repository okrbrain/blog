---
import BlogLayout from '../components/blog/BlogLayout.astro';
import CTAInline from '../components/blog/CTAInline.astro';
import PostCard from '../components/blog/PostCard.astro';
import { SITE_TITLE } from '../consts';
import { getFeaturedPosts, primaryCategories } from '../components/blog/mockData';

const featuredPosts = getFeaturedPosts();
---

<BlogLayout
	title={`${SITE_TITLE} | Conteudo para crescimento com OKRs`}
	description="Blog da OKR Brain com conteudos para gerar demanda organica: exemplos, dores, beneficios e comparativos de OKR."
>
	<section class="hero">
		<p class="eyebrow">OKR Brain Blog</p>
		<h1>O OKR Brain Blog esta voltando: mais simples, mais inteligente</h1>
		<p>
			Conteudo estrategico para escalar aquisicao organica com foco em IA para criar OKRs, simplicidade radical
			e execucao real.
		</p>
		<a class="button-primary" href="#">Quero acesso antecipado</a>
	</section>

	<section class="section-card" aria-labelledby="categorias">
		<h2 id="categorias">Categorias prioritarias</h2>
		<div class="grid">
			{
				primaryCategories.map((category) => (
					<a class="category-card" href={`/categoria/${category.slug}/`}>
						<h3>{category.name}</h3>
						<p>{category.description}</p>
					</a>
				))
			}
		</div>
	</section>

	<section class="section-card" aria-labelledby="destaques">
		<h2 id="destaques">Posts em destaque</h2>
		<div class="grid">
			{
				featuredPosts.map((post) => (
					<PostCard
						title={post.title}
						description={post.description}
						href={`/blog/${post.slug}/`}
						category={post.category}
						publishedAt={post.publishedAt}
					/>
				))
			}
		</div>
	</section>

	<CTAInline />
</BlogLayout>

<style>
	.hero {
		padding: 1.9rem;
		border-radius: var(--radius-lg);
		background: linear-gradient(140deg, #ffffff 0%, #f0fff6 65%, #e0ffeb 100%);
		border: 1px solid rgb(var(--gray-light));
		box-shadow: 0 8px 18px rgba(11, 24, 16, 0.08);
	}
	.grid {
		display: grid;
		gap: 1.1rem;
		grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
	}
	.category-card {
		display: block;
		background: linear-gradient(145deg, #ffffff 0%, #ecfff4 100%);
		border: 1px solid rgb(var(--gray-light));
		border-radius: var(--radius-md);
		padding: 1.1rem;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		transition: transform 0.2s ease, border-color 0.2s ease;
	}
	.category-card:hover {
		border-color: #5efc8d;
		transform: translateY(-2px);
	}
	.category-card h3 {
		font-size: 1.08rem;
		margin-bottom: 0.4rem;
	}
	.category-card p {
		margin: 0;
	}
</style>
