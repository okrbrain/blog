---
import BlogLayout from '../components/blog/BlogLayout.astro';
import CTAFinal from '../components/blog/CTAFinal.astro';
import PostCard from '../components/blog/PostCard.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

const posts = (
	await getCollection('blog', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true))
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = posts.slice(0, 6);

const categoryInfo: Record<string, { name: string; description: string }> = {
	'exemplos-de-okrs': {
		name: 'Exemplos de OKRs',
		description: 'Modelos prontos para diferentes contextos de negocio.',
	},
	'dores-e-dificuldades': {
		name: 'Dores e dificuldades',
		description: 'Principais gargalos ao implementar OKRs.',
	},
	'beneficios-de-okr': {
		name: 'Beneficios de OKR',
		description: 'Impacto real de OKRs na performance dos times.',
	},
	'estudos-de-caso': {
		name: 'Estudos de caso',
		description: 'Licoes aplicadas por equipes orientadas a metas.',
	},
	'comparacao-de-ferramentas': {
		name: 'Comparacao de ferramentas',
		description: 'Analises para escolher a ferramenta certa.',
	},
};

const categoryOrder = [
	'exemplos-de-okrs',
	'dores-e-dificuldades',
	'beneficios-de-okr',
	'estudos-de-caso',
	'comparacao-de-ferramentas',
];

const primaryCategories = categoryOrder
	.filter((slug) => posts.some((post) => post.data.categorySlug === slug))
	.map((slug) => ({
		slug,
		name: categoryInfo[slug]?.name ?? slug,
		description: categoryInfo[slug]?.description ?? 'Conteudos da categoria.',
	}));

const popularSearches = [
	'okr exemplos prontos',
	'como criar key results',
	'okr para time de produto',
	'metodologia okr para startups',
	'ferramenta de okr com ia',
];
---

<BlogLayout
	title={`${SITE_TITLE} | Conteudo sobre OKRs`}
	description="Conteudo pratico sobre OKRs para escala, consistencia e conversao."
>
	<section class="hero">
		<h1>OKR Brain</h1>
		<p class="hero-subtitle">
			Conteudo direto para criar OKRs melhores, executar com cadencia e conectar estrategia a resultado.
		</p>
	</section>

	<section class="section-card" aria-labelledby="ultimas-postagens">
		<h2 id="ultimas-postagens">Ultimas postagens</h2>
		<div class="grid">
			{
				latestPosts.map((post) => (
					<PostCard
						title={post.data.title}
						description={post.data.description}
						href={`/blog/${post.id}/`}
						category={post.data.category}
						publishedAt={post.data.pubDate.toISOString().slice(0, 10)}
					/>
				))
			}
		</div>
	</section>

	<section class="section-card" aria-labelledby="categorias">
		<h2 id="categorias">Principais categorias</h2>
		<div class="grid">
			{
				primaryCategories.map((category) => (
					<a class="category-card" href={`/categoria/${category.slug}/`}>
						<h3>{category.name}</h3>
						<p>{category.description}</p>
					</a>
				))
			}
		</div>
	</section>

	<section class="section-card" aria-labelledby="buscas-realizadas">
		<h2 id="buscas-realizadas">Buscas mais realizadas</h2>
		<ul class="search-list">
			{
				popularSearches.map((query) => (
					<li>
						<a href={`/blog/?q=${encodeURIComponent(query)}`}>{query}</a>
					</li>
				))
			}
		</ul>
	</section>

	<CTAFinal />
</BlogLayout>

<style>
	.hero {
		padding: 0.4rem 0 0;
		background: transparent;
		border: 0;
		box-shadow: none;
		text-align: left;
		margin-bottom: 1rem;
		max-width: 620px;
	}
	.hero h1 {
		font-size: clamp(1.2rem, 2.2vw, 1.5rem);
		font-weight: 700;
		line-height: 1.25;
		letter-spacing: normal;
		text-transform: none;
		font-style: normal;
		color: rgb(var(--black));
		margin-bottom: 0.35rem;
	}
	.hero-subtitle {
		font-size: 0.96rem;
		color: rgb(var(--gray-dark));
		margin: 0;
	}
	.grid {
		display: grid;
		gap: 1.1rem;
		grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
	}
	.category-card {
		display: block;
		background: linear-gradient(145deg, #ffffff 0%, #ecfff4 100%);
		border: 1px solid rgb(var(--gray-light));
		border-radius: var(--radius-md);
		padding: 1.1rem;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		transition: transform 0.2s ease, border-color 0.2s ease;
	}
	.category-card:hover {
		border-color: #5efc8d;
		transform: translateY(-2px);
	}
	.category-card h3 {
		font-size: 1.08rem;
		margin-bottom: 0.4rem;
	}
	.category-card p {
		margin: 0;
	}
	.search-list {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 0.75rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.search-list a {
		display: block;
		text-decoration: none;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		padding: 0.8rem;
		border-radius: var(--radius-sm);
		color: rgb(var(--gray-dark));
	}
	.search-list a:hover {
		border-color: #5efc8d;
	}
</style>
