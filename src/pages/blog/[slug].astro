---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogLayout from '../../components/blog/BlogLayout.astro';
import CTAFinal from '../../components/blog/CTAFinal.astro';
import CTAInline from '../../components/blog/CTAInline.astro';
import PostCard from '../../components/blog/PostCard.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true));
	return posts.map((post) => ({
		params: { slug: post.id },
	}));
}

const { slug } = Astro.params;
const allPosts = (
	await getCollection('blog', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true))
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const post = allPosts.find((entry) => entry.id === slug);

if (!post) {
	return Astro.redirect('/');
}

const relatedPosts = allPosts.filter((candidate) => post.data.relatedSlugs.includes(candidate.id));
const { Content } = await render(post as CollectionEntry<'blog'>);
---

<BlogLayout
	title={`${post.data.title} | OKR Brain`}
	description={post.data.description}
	ogType="article"
>
	<article>
		<header class="post-hero">
			<p class="meta">{post.data.category} - {post.data.pubDate.toISOString().slice(0, 10)}</p>
			<h1>{post.data.title}</h1>
			<p>{post.data.intro}</p>
		</header>

		<TableOfContents items={post.data.toc} />

		<section class="section-card" aria-labelledby="conteudo-principal">
			<h2 id="conteudo-principal">Conteudo principal</h2>
			<Content />
		</section>

		<section class="section-card" aria-labelledby="aplicacao-pratica">
			<h2 id="aplicacao-pratica">Aplicacao pratica</h2>
			<ul>
				{post.data.practicalApplication.map((item) => <li>{item}</li>)}
			</ul>
		</section>

		<section class="section-card" aria-labelledby="conexao-produto">
			<h2 id="conexao-produto">Conexao com o produto</h2>
			{post.data.productConnection.map((item) => <p>{item}</p>)}
		</section>

		<CTAInline />
		<CTAFinal />

		<section class="section-card" aria-labelledby="links-relacionados">
			<h2 id="links-relacionados">Leituras relacionadas</h2>
			<div class="related-grid">
				{
					relatedPosts.map((relatedPost) => (
						<PostCard
							title={relatedPost.data.title}
							description={relatedPost.data.description}
							href={`/blog/${relatedPost.id}/`}
							category={relatedPost.data.category}
							publishedAt={relatedPost.data.pubDate.toISOString().slice(0, 10)}
						/>
					))
				}
			</div>
		</section>
	</article>
</BlogLayout>

<style>
	.post-hero {
		padding: 1.7rem;
		border-radius: var(--radius-lg);
		background: linear-gradient(140deg, #ffffff 0%, #effff4 70%, #dfffe9 100%);
		border: 1px solid rgb(var(--gray-light));
		box-shadow: 0 8px 18px rgba(11, 24, 16, 0.07);
	}
	.meta {
		margin: 0;
		font-size: 0.82rem;
		color: rgb(var(--gray));
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.related-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1.1rem;
	}
</style>
