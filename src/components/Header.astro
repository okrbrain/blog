---
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2>
			<a href="/" aria-label={SITE_TITLE} class="brand-link">
				<img src="/favicon.png" alt="" class="brand-icon" />
				<span class="brand-text">OKR Brain</span>
			</a>
		</h2>
		<div class="internal-links">
			<a href="/">Blog</a>
			<a href="https://okrbrain.com/" target="_blank" rel="noreferrer">App</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.2rem;
		background: rgba(255, 255, 255, 0.92);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid rgba(120, 132, 128, 0.2);
	}
	h2 {
		margin: 0;
	}

	.brand-link,
	.brand-link.active {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		color: rgb(var(--black));
		text-decoration: none;
		padding: 0;
		background: transparent;
	}
	.brand-icon {
		display: block;
		height: 30px;
		width: auto;
		border-radius: 6px;
	}
	.brand-text {
		display: inline-block;
		font-family: "Space Grotesk", system-ui, sans-serif;
		font-size: 1.08rem;
		font-weight: 700;
		line-height: 1;
		color: rgb(var(--black));
		white-space: nowrap;
	}
	nav {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 68px;
	}
	nav a {
		padding: 0.6rem 0.7rem;
		color: rgb(var(--gray-dark));
		border-bottom: 2px solid transparent;
		text-decoration: none;
		border-radius: 8px;
		transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
	}
	nav a:hover {
		color: rgb(var(--black));
		background: rgba(94, 252, 141, 0.12);
	}
	.internal-links {
		display: flex;
		gap: 0.35rem;
	}
	@media (max-width: 720px) {
		header {
			padding: 0 0.8rem;
		}
		nav {
			min-height: 56px;
		}
		.internal-links {
			gap: 0.1rem;
		}
		.brand-icon {
			height: 20px;
		}
		.brand-text {
			font-size: 0.92rem;
		}
		nav a {
			padding: 0.32rem 0.5rem;
			font-size: 0.86rem;
		}
	}
</style>
