---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p class="headline">Gestao de OKRs sem complicacao.</p>
		<p class="copy">&copy; {today.getFullYear()} OKR Brain. Todos os direitos reservados.</p>
	</div>
	<div class="social-links">
		<a href="https://github.com/okrbrain/blog" target="_blank">
			<span class="sr-only">Ir para o GitHub do blog</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" astro-icon="social/github"
				><path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path></svg
			>
		</a>
	</div>
</footer>
<style>
	footer {
		padding: 2.4rem 1rem 3rem;
		background: var(--brand-dark-gradient);
		color: rgba(245, 255, 250, 0.9);
		text-align: center;
	}
	.footer-inner {
		max-width: 960px;
		margin: 0 auto;
	}
	.headline {
		margin: 0;
		font-weight: 700;
		font-size: 1.05rem;
	}
	.copy {
		margin: 0.35rem 0 0;
		font-size: 0.92rem;
		opacity: 0.9;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1.1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgba(245, 255, 250, 0.88);
	}
	.social-links a:hover {
		color: var(--brand-green);
	}
</style>
