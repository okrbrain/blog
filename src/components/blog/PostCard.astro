---
interface Props {
	title: string;
	description: string;
	href: string;
	category: string;
	publishedAt: string;
}

const { title, description, href, category, publishedAt } = Astro.props;
---

<article class="post-card">
	<p class="meta"><span>{category}</span> - {publishedAt}</p>
	<h3><a href={href}>{title}</a></h3>
	<p>{description}</p>
</article>

<style>
	.post-card {
		border: 1px solid rgb(var(--gray-light));
		border-radius: var(--radius-md);
		padding: 1.15rem;
		background: linear-gradient(145deg, #ffffff 0%, #f1fff6 100%);
		box-shadow: 0 2px 10px rgba(11, 24, 16, 0.05);
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
	}
	.post-card:hover {
		transform: translateY(-2px);
		border-color: rgba(53, 219, 109, 0.45);
		box-shadow: var(--box-shadow);
	}
	.meta {
		margin: 0 0 0.5rem 0;
		font-size: 0.8rem;
		color: rgb(var(--gray));
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.meta span {
		color: #1f9e52;
		font-weight: 700;
	}
	h3 {
		margin: 0 0 0.45rem 0;
		font-size: 1.2rem;
	}
	h3 a {
		text-decoration: none;
		color: rgb(var(--black));
	}
	h3 a:hover {
		color: #1f9e52;
	}
</style>
